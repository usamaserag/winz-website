{
  "name": "winz-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/optimize-images.mjs && vite build --outDir dist/client",
    "build:client": "npm run build",
    "build:analyze": "ANALYZE=true npm run build",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 50",
    "preview": "vite preview --outDir dist/client"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "framer-motion": "^10.16.4",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  }
}
